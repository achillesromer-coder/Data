<script>
window.W6_DATASPACE_MASTER_CONTRACT = {
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://romer-industries.local/schemas/w6-dataspace-master-contract.schema.json",
  "title": "W6 Dataspace Master Contract",
  "description": "Canonical data contract for W6 Asset Library Dataspace. This schema defines source ingestion, normalization, zoning, clustering, publish payloads, QA state, run logs, pass-off packs, and cross-workspace exchange rules for Squarespace front-end embeds and Drive-backed dataspace operations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractMeta",
    "embedRules",
    "sourceRegistry",
    "pipelineConfig",
    "taxonomyRules",
    "normalizationRules",
    "zoningRules",
    "clusteringRules",
    "scoringRules",
    "qaRules",
    "publishRules",
    "workspaceResponsibilities",
    "records",
    "derivedProducts",
    "queues",
    "handoffContracts"
  ],
  "properties": {
    "contractMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractId",
        "contractName",
        "version",
        "status",
        "ownerWorkspace",
        "author",
        "timezone",
        "units",
        "dateCreatedUtc",
        "dateModifiedUtc",
        "sourceOfTruth"
      ],
      "properties": {
        "contractId": { "type": "string", "const": "w6-dataspace-master-contract" },
        "contractName": { "type": "string", "const": "W6 Dataspace Master Contract" },
        "version": { "type": "string", "const": "1.0.0" },
        "status": { "type": "string", "enum": ["draft", "active", "deprecated"], "const": "active" },
        "ownerWorkspace": { "type": "string", "const": "W6" },
        "author": { "type": "string", "const": "Achilles Scout" },
        "timezone": { "type": "string", "const": "Australia/Brisbane" },
        "units": {
          "type": "object",
          "additionalProperties": false,
          "required": ["distanceOrbit", "distanceBody", "density", "velocity", "mass", "angles", "time"],
          "properties": {
            "distanceOrbit": { "type": "string", "const": "AU" },
            "distanceBody": { "type": "string", "const": "km" },
            "density": { "type": "string", "const": "g/cm^3" },
            "velocity": { "type": "string", "const": "km/s" },
            "mass": { "type": "string", "const": "kg" },
            "angles": { "type": "string", "const": "deg" },
            "time": { "type": "string", "const": "UTC ISO-8601" }
