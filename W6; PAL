              "refreshPolicy": { "type": "string", "enum": ["manual", "hourly", "daily", "weekly", "on_publish"] },
              "ownerWorkspace": { "type": "string", "enum": ["W1", "W2", "W3", "W4", "W5", "W6", "LIB"] }
            }
