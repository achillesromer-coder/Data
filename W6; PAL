          "type": "object",
          "additionalProperties": false,
          "required": ["mayHoldFullRegistry", "mayHoldQaState", "mayHoldRunLogs"],
          "properties": {
            "mayHoldFullRegistry": { "type": "boolean", "const": true },
            "mayHoldQaState": { "type": "boolean", "const": true },
            "mayHoldRunLogs": { "type": "boolean", "const": true }
