              "ingestClass": "registry",
              "refreshPolicy": "manual",
              "ownerWorkspace": "W6"
            },
            {
              "sourceId": "src-obj-library",
              "name": "Asteroids OBJ Library",
              "sourceType": "obj_library",
              "isAuthoritative": false,
              "status": "indexed",
              "driveOrEndpoint": "https://drive.google.com/drive/folders/12rRVIAAn-MQgHJ1zCC6PfC8TNi3NEA3P",
              "ingestClass": "mesh",
              "refreshPolicy": "manual",
              "ownerWorkspace": "W6"
