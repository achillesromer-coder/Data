<script>
(function () {
  window.W6App = window.W6App || {};

  var existing = window.W6App.config || {};
  var WEB_APP_URL = existing.webAppUrl || "https://script.google.com/macros/s/AKfycby4prqrsLx-iT0pETiK3b-zx-OPqapOdMZiPc_7E6pZ35BwIhzlIqX-CxlLBdj7mhsL/exec";

  function clone(v) {
    return JSON.parse(JSON.stringify(v));
  }

  window.W6App.config = {
    workspaceId: "W6",
    workspaceName: "Asset Library Dataspace",
    webAppUrl: WEB_APP_URL,
    statusUrl: WEB_APP_URL + "?action=status",
    commandUrl: WEB_APP_URL,
    pollMs: 15000,
    fetchTimeoutMs: 12000,
    engine: {
      id: "Engine_SBDB",
      readSurface: "Engine Handoff Block 1",
      commandSurface: "Engine Handoff Block 3",
      queueSource: "Engine SBDB Block 4",
      primaryCommands: [
        "RUN_SBDB_ENGINE",
        "PAUSE_SBDB_ENGINE",
        "RESUME_SBDB_ENGINE",
        "STOP_SBDB_ENGINE",
        "RESET_STALE_COMMANDS"
      ],
      debugCommands: [
        "FIND_NEXT_QUEUE",
        "LOCK_QUEUE_ITEM",
        "MARK_FETCH_STARTED",
        "MARK_DATA_RETURNED",
        "ROUTE_TO_REVIEW",
        "MARK_WRITEBACK_COMPLETE",
        "FETCH_NEXT_QUEUE",
        "RETRY_ACTIVE_ITEM"
      ]
    },
    pipelineActions: [
      "ingest",
      "normalize",
      "zone",
      "cluster",
      "qa",
      "publish",
      "passoff"
    ]
  };

  window.W6App.events = window.W6App.events || {};

  window.W6App.on = function (name, fn) {
    if (!window.W6App.events[name]) window.W6App.events[name] = [];
    window.W6App.events[name].push(fn);
    return function () {
      window.W6App.events[name] = (window.W6App.events[name] || []).filter(function (x) { return x !== fn; });
    };
  };

  window.W6App.emit = function (name, payload) {
    (window.W6App.events[name] || []).forEach(function (fn) {
      try { fn(payload); } catch (err) { console.error(err); }
    });
  };

  window.W6App.helpers = window.W6App.helpers || {};

  window.W6App.helpers.safeText = function (value) {
    return (value === null || value === undefined || value === "") ? "—" : String(value);
  };

  window.W6App.helpers.fetchWithTimeout = async function (url, options, timeoutMs) {
    var controller = new AbortController();
    var timer = setTimeout(function () { controller.abort(); }, timeoutMs || window.W6App.config.fetchTimeoutMs);
    try {
      return await fetch(url, Object.assign({}, options || {}, { signal: controller.signal }));
    } finally {
      clearTimeout(timer);
    }
  };

  window.W6App.logs = window.W6App.logs || [];

  window.W6App.pushLog = function (message, origin) {
    var entry = {
      timeUtc: new Date().toISOString(),
      origin: origin || "W6",
      message: String(message || "")
    };
    window.W6App.logs.unshift(entry);
    if (window.W6App.logs.length > 200) window.W6App.logs.length = 200;
    window.W6App.emit("log:entry", clone(entry));
    return entry;
  };

  window.W6App.getRecentLogs = function () {
    return clone(window.W6App.logs);
  };

  window.W6App.getEngineBridgeConfig = function () {
    return clone({
      webAppUrl: window.W6App.config.webAppUrl,
      statusUrl: window.W6App.config.statusUrl,
      commandUrl: window.W6App.config.commandUrl,
      primaryCommands: window.W6App.config.engine.primaryCommands,
      debugCommands: window.W6App.config.engine.debugCommands
    });
  };

  window.W6App.runPipelineAction = async function (actionName) {
    var action = String(actionName || "").trim();
    var primary = window.W6App.config.engine.primaryCommands.indexOf(action) !== -1;
    var debug = window.W6App.config.engine.debugCommands.indexOf(action) !== -1;

    if ((primary || debug) && window.W6App.sbdb && typeof window.W6App.sbdb.postCommand === "function") {
      return window.W6App.sbdb.postCommand(action);
    }

    window.W6App.pushLog("Local pipeline action acknowledged: " + action, "PIPELINE");
    window.W6App.emit("pipeline:action", { action: action, timeUtc: new Date().toISOString() });
    return { ok: true, localOnly: true, action: action };
  };

  if (window.W6_DATASPACE_MASTER_CONTRACT &&
      window.W6_DATASPACE_MASTER_CONTRACT.properties &&
      window.W6_DATASPACE_MASTER_CONTRACT.properties.contractMeta &&
      window.W6_DATASPACE_MASTER_CONTRACT.properties.contractMeta.properties) {
    try {
      window.W6_DATASPACE_MASTER_CONTRACT.properties.contractMeta.properties.version.const = "1.1.0";
    } catch (err) {}
  }

  window.W6App.pushLog("W6 runtime/config bridge loaded.", "BOOT");
})();
</script>
