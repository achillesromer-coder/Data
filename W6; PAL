              "driveOrEndpoint": "https://drive.google.com/drive/folders/1clPyKU1C_Prd-a4g-Cbl2RZQybLL2oag",
              "ingestClass": "manifest",
              "refreshPolicy": "manual",
              "ownerWorkspace": "W6"
