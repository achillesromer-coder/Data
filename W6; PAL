      }
    },
    "records": {
      "type": "object",
      "additionalProperties": false,
      "required": ["objectRegistry"],
      "properties": {
        "objectRegistry": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/objectRecord" },
          "default": [
            {
              "objectId": "16",
              "objectName": "Psyche",
              "zoneId": "MBA",
              "clusterId": "MB-1",
              "semiMajorAxisAu": 2.922,
              "eccentricity": 0.134,
              "inclinationDeg": 3.1,
              "diameterKm": 222,
              "densityGcc": 3.99,
              "taxonomy": "M",
              "rawTaxonomy": "M",
              "hasMesh": false,
              "hasMissionReference": true,
              "completenessScore": 90,
              "readinessScore": 78,
              "strategicScore": 88,
              "sourceIds": ["src-drive-root", "src-control-workbook"],
              "provenanceNote": "Mission validated metal-rich main belt target"
            },
            {
              "objectId": "101955",
              "objectName": "Bennu",
              "zoneId": "Apollo",
              "clusterId": "AP-1",
              "semiMajorAxisAu": 1.126,
              "eccentricity": 0.204,
              "inclinationDeg": 6.0,
              "diameterKm": 0.49,
              "densityGcc": 1.26,
              "taxonomy": "B",
