      }
    },
    "derivedProducts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zoneSummary", "clusterSummary", "frontEndPayload", "selectedObjectPayloads", "qaStatus", "runLog"],
      "properties": {
        "zoneSummary": {
          "type": "array",
          "items": { "$ref": "#/$defs/zoneSummaryRow" }
        },
        "clusterSummary": {
          "type": "array",
