            "publish": { "type": "array", "items": { "type": "string" }, "default": ["front_end_payload.json", "selected_object_payloads.json"] },
            "passoff": { "type": "array", "items": { "type": "string" }, "default": ["passoff_pack.json"] }
          }
        }
      }
    },
    "taxonomyRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acceptedTaxonomyPrefixes", "metallicityHints", "unknownPolicy"],
      "properties": {
        "acceptedTaxonomyPrefixes": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["M", "S", "Sq", "Q", "C", "Cg", "Ch", "B", "D", "P", "V", "X", "E"]
        },
        "metallicityHints": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "high": { "type": "array", "items": { "type": "string" }, "default": ["M", "X", "E"] },
            "medium": { "type": "array", "items": { "type": "string" }, "default": ["S", "Sq", "V"] },
            "low": { "type": "array", "items": { "type": "string" }, "default": ["C", "Cg", "Ch", "B", "D", "P"] }
          }
        },
        "unknownPolicy": { "type": "string", "const": "retain raw value, mark qa flag, do not discard record" }
      }
    },
    "normalizationRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mandatoryFields", "fallbackRules", "completenessScoring"],
      "properties": {
        "mandatoryFields": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["objectId", "objectName", "semiMajorAxisAu", "eccentricity", "inclinationDeg", "zoneId", "clusterId", "sourceIds"]
        },
        "fallbackRules": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "densityGcc": { "type": "string", "const": "nullable, never fabricated" },
            "diameterKm": { "type": "string", "const": "nullable, never fabricated" },
            "taxonomy": { "type": "string", "const": "nullable, retain rawTaxonomy if unresolved" },
            "missionReference": { "type": "string", "const": "false if no evidence" },
            "meshReference": { "type": "string", "const": "false if no file link" }
          }
        },
        "completenessScoring": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxScore", "weights"],
          "properties": {
            "maxScore": { "type": "integer", "const": 100 },
            "weights": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "orbitalElements": { "type": "integer", "const": 30 },
                "physicalProperties": { "type": "integer", "const": 25 },
                "taxonomy": { "type": "integer", "const": 10 },
                "meshReference": { "type": "integer", "const": 10 },
                "missionReference": { "type": "integer", "const": 10 },
                "provenance": { "type": "integer", "const": 15 }
              }
            }
          }
        }
      }
    },
    "zoningRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zoneDefinitions", "emptyZonePolicy"],
      "properties": {
        "zoneDefinitions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["zoneId", "label", "selectionRule"],
            "properties": {
              "zoneId": { "type": "string", "enum": ["IEO", "Aten", "Apollo", "Amor", "MBA", "Trojan", "IMB"] },
              "label": { "type": "string" },
              "selectionRule": { "type": "string" }
            }
          },
          "default": [
            { "zoneId": "IEO", "label": "Inner-Earth Objects", "selectionRule": "Q < 0.983 AU" },
            { "zoneId": "Aten", "label": "Aten Group", "selectionRule": "a < 1 AU and Q > 0.983 AU" },
            { "zoneId": "Apollo", "label": "Apollo Group", "selectionRule": "a > 1 AU and q < 1.017 AU" },
            { "zoneId": "Amor", "label": "Amor Group", "selectionRule": "1.017 AU < q < 1.3 AU" },
            { "zoneId": "MBA", "label": "Main Belt Asteroids", "selectionRule": "2.0 AU <= a <= 3.3 AU" },
            { "zoneId": "Trojan", "label": "Jupiter Trojans", "selectionRule": "co-orbital with Jupiter L4/L5 population" },
            { "zoneId": "IMB", "label": "Inner Main Belt", "selectionRule": "1.8 AU <= a < 2.0 AU" }
          ]
        },
        "emptyZonePolicy": { "type": "string", "const": "retain zone row with count 0 for UI consistency" }
      }
    },
    "clusteringRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clusterMode", "rules"],
      "properties": {
        "clusterMode": { "type": "string", "const": "semi-hard operational clusters" },
        "rules": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "cluster inside zone only",
            "cluster names must remain stable across publishes unless QA override approved",
            "minimum one object per cluster",
            "singletons allowed",
            "cluster summary must expose count, meanA, meanDvProxy, meanReadiness, narrativeSummary"
          ]
        }
      }
    },
    "scoringRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readinessScore", "strategicScore"],
      "properties": {
        "readinessScore": {
          "type": "object",
          "additionalProperties": false,
          "required": ["weights"],
          "properties": {
            "weights": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "completeness": { "type": "number", "const": 0.35 },
                "missionValidation": { "type": "number", "const": 0.15 },
                "meshAvailability": { "type": "number", "const": 0.10 },
                "accessibilityProxy": { "type": "number", "const": 0.20 },
                "taxonomyStrategicFit": { "type": "number", "const": 0.20 }
              }
            }
          }
        },
        "strategicScore": {
          "type": "object",
          "additionalProperties": false,
          "required": ["weights"],
          "properties": {
            "weights": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "metallicityProxy": { "type": "number", "const": 0.30 },
                "sizeUtility": { "type": "number", "const": 0.15 },
                "accessibilityProxy": { "type": "number", "const": 0.20 },
                "missionEvidence": { "type": "number", "const": 0.15 },
                "completeness": { "type": "number", "const": 0.20 }
              }
            }
          }
        }
      }
    },
    "qaRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criticalFlags", "publishThresholds"],
      "properties": {
        "criticalFlags": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "duplicateObjectId",
            "missingSemiMajorAxis",
            "missingEccentricity",
            "missingInclination",
            "unresolvedZone",
            "orphanCluster",
            "orphanMeshLink"
          ]
        },
        "publishThresholds": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxCriticalFlags", "minMeanCompleteness", "requireZoneRows", "requireClusterRows"],
          "properties": {
            "maxCriticalFlags": { "type": "integer", "const": 0 },
            "minMeanCompleteness": { "type": "number", "const": 70 },
            "requireZoneRows": { "type": "boolean", "const": true },
            "requireClusterRows": { "type": "boolean", "const": true }
          }
        }
      }
    },
    "publishRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frontEndPayload", "selectedObjectPayload", "passoffPack"],
      "properties": {
        "frontEndPayload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxObjectsInitial", "requiredSections"],
          "properties": {
            "maxObjectsInitial": { "type": "integer", "const": 0 },
            "requiredSections": {
              "type": "array",
              "items": { "type": "string" },
              "default": ["zoneSummary", "clusterSummary", "sourceSummary", "uiStateDefaults"]
            }
          }
        },
        "selectedObjectPayload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["loadedOnDemand", "requiredSections"],
          "properties": {
            "loadedOnDemand": { "type": "boolean", "const": true },
            "requiredSections": {
              "type": "array",
              "items": { "type": "string" },
              "default": ["objectDetail", "provenance", "meshAvailability", "missionReference", "passoffEligibility"]
            }
          }
        },
        "passoffPack": {
          "type": "object",
          "additionalProperties": false,
          "required": ["targetTypes", "requiredSections"],
          "properties": {
            "targetTypes": {
              "type": "array",
              "items": { "type": "string", "enum": ["zone", "cluster", "object"] },
              "default": ["cluster", "object"]
            },
            "requiredSections": {
              "type": "array",
              "items": { "type": "string" },
              "default": ["selectionMeta", "selectedRecords", "scores", "sourceRefs", "qaState", "downstreamRouting"]
            }
          }
        }
      }
    },
    "workspaceResponsibilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["W1", "W2", "W3", "W4", "W5", "W6"],
      "properties": {
        "W1": { "type": "array", "items": { "type": "string" }, "default": ["consume candidate shortlist from W6", "run capture feasibility", "emit capture_result payload"] },
        "W2": { "type": "array", "items": { "type": "string" }, "default": ["consume W1 payload and W3 field config", "simulate catch/hold/launch state", "emit hold envelope"] },
        "W3": { "type": "array", "items": { "type": "string" }, "default": ["author field configuration", "author safety envelope", "emit field_config payload"] },
        "W4": { "type": "array", "items": { "type": "string" }, "default": ["consume W1 W2 W5 outputs", "author route and throughput model"] },
