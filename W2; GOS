  function envelopeTableHTML(m) {
    return '<table class="'+NS+'-table"><thead><tr><th>Parameter</th><th>Value</th><th>Assessment</th></tr></thead><tbody>'
      + tableRow("Approach velocity", fmt(STATE.approachVel,1)+" m/s", STATE.approachVel < 2 ? "safe" : STATE.approachVel < 5 ? "conditional" : "high")
      + tableRow("Alignment error", STATE.alignmentErr+"°", STATE.alignmentErr < 8 ? "safe" : STATE.alignmentErr < 16 ? "conditional" : "high")
      + tableRow("Hold margin", STATE.holdMargin+"%", STATE.holdMargin > 20 ? "strong" : "thin")
      + tableRow("Safety envelope", fmt(m.safetyEnvelope,1)+"/100", m.safetyEnvelope > 75 ? "good" : m.safetyEnvelope > 55 ? "watch" : "poor")
      + tableRow("State", esc(m.stateName), m.stateName.toLowerCase())
      + '</tbody></table>';
  }

  function tableRow(a, b, c) {
    return '<tr><td>'+a+'</td><td>'+b+'</td><td>'+c+'</td></tr>';
  }

  function routeTableHTML() {
    var path = activeRoute();
    return '<table class="'+NS+'-table"><thead><tr><th>Step</th><th>Node</th><th>Phase</th><th>Status</th></tr></thead><tbody>'
      + path.map(function (n, i) {
          var phase = i === 0 && path.length > 1 ? "Origin / inbound" : i === path.length - 1 ? "Destination / handoff" : "Relay";
          var status = i === 0 ? "active" : i === path.length - 1 ? "pending arrival" : "queued";
          return '<tr><td>'+(i+1)+'</td><td>'+esc(n)+'</td><td>'+phase+'</td><td>'+status+'</td></tr>';
        }).join("")
      + '</tbody></table>';
  }

  function activeRoute() {
    return {
      "Inbound to GEO": ["NEA Inbound", "GEO Luke II"],
      "Inbound to LEO": ["NEA Inbound", "GEO Luke II", "LEO Depot"],
      "Hold at GEO": ["GEO Luke II"],
      "Outbound Lunar": ["GEO Luke II", "Cislunar Node"],
      "Outbound Mars": ["GEO Luke II", "Cislunar Node", "Mars Relay"]
    }[STATE.routeMode] || ["NEA Inbound", "GEO Luke II"];
  }

  function bind() {
    mount.querySelectorAll("."+NS+"-tab").forEach(function (el) {
      el.addEventListener("click", function () {
        STATE.tab = this.getAttribute("data-tab");
        render();
      });
    });

    [
      [NS+"-mode","mode"],
      [NS+"-route","routeMode"],
      [NS+"-pc","payloadClass"]
    ].forEach(function (pair) {
      var el = mount.querySelector("#"+pair[0]);
      if (el) {
        el.addEventListener("change", function () {
          STATE[pair[1]] = this.value;
          pushLog("config", pair[1] + " updated");
          render();
        });
      }
    });

    [
      [NS+"-cr","catchRadius"],
      [NS+"-av","approachVel"],
      [NS+"-hf","holdingForce"],
      [NS+"-cc","coilCurrent"],
      [NS+"-ef","emFreq"],
      [NS+"-mass","massKg"],
      [NS+"-ae","alignmentErr"],
      [NS+"-hm","holdMargin"],
      [NS+"-la","launchAssist"]
    ].forEach(function (pair) {
      var el = mount.querySelector("#"+pair[0]);
      if (el) {
        el.addEventListener("input", function () {
          STATE[pair[1]] = parseFloat(this.value);
          render();
        });
      }
    });

    mount.querySelectorAll("."+NS+"-btn[data-action]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var a = this.getAttribute("data-action");
        if (a === "run") {
          var m = model();
          pushLog("run", "W2 run logged | state " + m.stateName + " | capture " + fmt(m.captureScore,1) + " | hold " + fmt(m.holdStability,1));
          render();
          return;
        }
        if (a === "export") {
          var payload = {
            mode: STATE.mode,
            routeMode: STATE.routeMode,
            payloadClass: STATE.payloadClass,
            catchRadiusM: STATE.catchRadius,
            approachVelocityMs: STATE.approachVel,
            holdingForceN: STATE.holdingForce,
            coilCurrentA: STATE.coilCurrent,
            emFrequencyHz: STATE.emFreq,
            payloadMassKg: STATE.massKg,
            alignmentErrorDeg: STATE.alignmentErr,
            holdMarginPct: STATE.holdMargin,
            launchAssistPct: STATE.launchAssist,
            metrics: model(),
            exportedUtc: new Date().toISOString()
          };
          var blob = new Blob([JSON.stringify(payload, null, 2)], { type: "application/json" });
          var url = URL.createObjectURL(blob);
          var link = document.createElement("a");
          link.href = url;
          link.download = "w2_catch_hold_payload.json";
          link.click();
          URL.revokeObjectURL(url);
          pushLog("export", "Catch/hold payload exported");
          render();
          return;
        }
        STATE.selectedSweep = a;
        pushLog("sweep", "Sweep triggered: " + a.toUpperCase());
        render();
      });
    });
  }

  function drawFieldCanvas() {
    var c = mount.querySelector("#"+NS+"-field-canvas");
    if (!c) return;
    var rect = c.parentElement.getBoundingClientRect();
    var W = Math.max(320, Math.floor(rect.width));
    var H = Math.max(260, Math.floor(rect.height));
    c.width = W; c.height = H;
    var ctx = c.getContext("2d");
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle = "#0a0e1a";
    ctx.fillRect(0,0,W,H);

    var cx = W / 2, cy = H / 2;
    var rings = 6;
    for (var i = 1; i <= rings; i++) {
      var r = i * (Math.min(W,H) * 0.06 + STATE.catchRadius * 0.08);
      var alpha = Math.max(0.06, 0.36 - i * 0.04);
      ctx.beginPath();
      ctx.arc(cx, cy, r * 0.2, 0, Math.PI * 2);
      ctx.strokeStyle = "rgba(123,44,191," + alpha + ")";
      ctx.lineWidth = 2 - i * 0.18;
      ctx.stroke();
    }

    ctx.beginPath();
    ctx.arc(cx, cy, 12, 0, Math.PI * 2);
    ctx.fillStyle = C.purple;
    ctx.fill();

    ctx.beginPath();
    ctx.arc(cx, cy, 20, 0, Math.PI * 2);
    ctx.strokeStyle = "rgba(123,44,191,.65)";
    ctx.lineWidth = 3;
    ctx.stroke();

    var avs = Math.min(W,H) * 0.34;
    ctx.strokeStyle = "rgba(0,255,136,.75)";
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(cx + avs, cy - avs * 0.25);
    ctx.lineTo(cx + 24, cy);
    ctx.stroke();

    ctx.beginPath();
    ctx.arc(cx + avs, cy - avs * 0.25, 6, 0, Math.PI * 2);
    ctx.fillStyle = "rgba(0,255,136,.88)";
    ctx.fill();

    for (var a = 0; a < 8; a++) {
      var ang = a / 8 * Math.PI * 2;
      var r2 = Math.min(W,H) * 0.16;
      ctx.beginPath();
      ctx.moveTo(cx + Math.cos(ang) * r2, cy + Math.sin(ang) * r2);
      ctx.lineTo(cx + Math.cos(ang) * (r2 - 14), cy + Math.sin(ang) * (r2 - 14));
      ctx.strokeStyle = "rgba(123,44,191,.45)";
      ctx.lineWidth = 1.4;
      ctx.stroke();
    }
  }

  function drawForceCanvas() {
    var c = mount.querySelector("#"+NS+"-force-canvas");
    if (!c) return;
    var rect = c.parentElement.getBoundingClientRect();
    var W = Math.max(320, Math.floor(rect.width));
    var H = Math.max(260, Math.floor(rect.height));
    c.width = W; c.height = H;
    var ctx = c.getContext("2d");
    var m = model();

    ctx.clearRect(0,0,W,H);
    ctx.fillStyle = "#0a0e1a";
    ctx.fillRect(0,0,W,H);

    var baseY = H * 0.72;
    var leftX = W * 0.20;
    var barW = W * 0.18;
    var scale = Math.max(m.effectiveHold, m.captureDemand, 1);

    ctx.fillStyle = C.amber;
    ctx.fillRect(leftX, baseY - (m.captureDemand / scale) * H * 0.46, barW, (m.captureDemand / scale) * H * 0.46);

    ctx.fillStyle = C.green;
    ctx.fillRect(leftX + W * 0.30, baseY - (m.effectiveHold / scale) * H * 0.46, barW, (m.effectiveHold / scale) * H * 0.46);

    ctx.fillStyle = C.text;
    ctx.font = "12px Inter, sans-serif";
    ctx.fillText("Capture Demand", leftX, baseY + 20);
    ctx.fillText("Effective Hold", leftX + W * 0.30, baseY + 20);

    ctx.fillStyle = C.muted;
    ctx.font = "11px Inter, sans-serif";
    ctx.fillText(fmt(m.captureDemand,1), leftX + 8, baseY - (m.captureDemand / scale) * H * 0.46 - 8);
    ctx.fillText(fmt(m.effectiveHold,1), leftX + W * 0.30 + 8, baseY - (m.effectiveHold / scale) * H * 0.46 - 8);
  }

  function drawEnvelopeCanvas() {
    var c = mount.querySelector("#"+NS+"-envelope-canvas");
    if (!c) return;
    var rect = c.parentElement.getBoundingClientRect();
    var W = Math.max(320, Math.floor(rect.width));
    var H = Math.max(260, Math.floor(rect.height));
    c.width = W; c.height = H;
    var ctx = c.getContext("2d");

    ctx.clearRect(0,0,W,H);
    ctx.fillStyle = "#0a0e1a";
    ctx.fillRect(0,0,W,H);

    var cols = 18, rows = 12;
    var cw = W / cols, rh = H / rows;
    for (var y = 0; y < rows; y++) {
      for (var x = 0; x < cols; x++) {
        var vel = (x / (cols - 1)) * 10;
        var err = (y / (rows - 1)) * 30;
        var score = 96
          - vel * 8
          - err * 2.1
          + STATE.holdMargin * 0.55
          + STATE.holdingForce * 0.03
          - STATE.massKg * 0.002;
        score = Math.max(0, Math.min(100, score));
        ctx.fillStyle = score > 75 ? "rgba(0,255,136,.72)" : score > 55 ? "rgba(255,170,0,.70)" : "rgba(255,91,91,.65)";
        ctx.fillRect(x*cw + 1, y*rh + 1, cw - 2, rh - 2);
      }
    }

    ctx.fillStyle = C.muted;
    ctx.font = "11px Inter, sans-serif";
    ctx.fillText("Approach velocity →", 10, H - 8);
    ctx.save();
    ctx.translate(10, H - 24);
    ctx.rotate(-Math.PI/2);
    ctx.fillText("Alignment error ↑", 0, 0);
    ctx.restore();
  }

  function drawRouteCanvas() {
    var c = mount.querySelector("#"+NS+"-route-canvas");
    if (!c) return;
    var rect = c.parentElement.getBoundingClientRect();
    var W = Math.max(320, Math.floor(rect.width));
    var H = Math.max(260, Math.floor(rect.height));
    c.width = W; c.height = H;
    var ctx = c.getContext("2d");

    ctx.clearRect(0,0,W,H);
    ctx.fillStyle = "#0a0e1a";
    ctx.fillRect(0,0,W,H);

    var path = activeRoute();
    path.forEach(function (name, i) {
      var n = ROUTE_NODES[name];
      if (!n) return;
      if (i < path.length - 1) {
        var next = ROUTE_NODES[path[i+1]];
        ctx.beginPath();
        ctx.moveTo(n.x * W, n.y * H);
        ctx.lineTo(next.x * W, next.y * H);
        ctx.strokeStyle = C.green;
        ctx.lineWidth = 3;
        ctx.stroke();
      }
    });

    Object.keys(ROUTE_NODES).forEach(function (name) {
      var n = ROUTE_NODES[name];
      var active = path.indexOf(name) !== -1;
      ctx.beginPath();
      ctx.arc(n.x * W, n.y * H, active ? 9 : 6, 0, Math.PI*2);
      ctx.fillStyle = active ? C.green : C.cyan;
      ctx.fill();
      ctx.fillStyle = C.text;
      ctx.font = "11px Inter, sans-serif";
      ctx.fillText(name, n.x * W + 10, n.y * H - 8);
    });
  }

  function tickUTC() {
    var el = mount.querySelector("#"+NS+"-utc");
    if (el) el.textContent = new Date().toUTCString().replace("GMT","UTC");
  }

  render();
  setInterval(function () { tickUTC(); }, 1000);

  window.W2App = window.W2App || {};
  window.W2App.state = function () { return JSON.parse(JSON.stringify(STATE)); };
  window.W2App.model = model;
  window.W2App.rerender = render;
})();
