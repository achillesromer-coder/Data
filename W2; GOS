  function renderTab() {
    var vp = mount.querySelector("#"+NS+"-viewport");
    if (!vp) return;
    if (STATE.tab === "field") vp.innerHTML = renderField();
    if (STATE.tab === "force") vp.innerHTML = renderForce();
    if (STATE.tab === "envelope") vp.innerHTML = renderEnvelope();
    if (STATE.tab === "route") vp.innerHTML = renderRoute();
    if (STATE.tab === "exports") vp.innerHTML = renderExports();
    if (STATE.tab === "connections") vp.innerHTML = renderConnections();

    if (STATE.tab === "field") drawFieldCanvas();
    if (STATE.tab === "force") drawForceCanvas();
    if (STATE.tab === "envelope") drawEnvelopeCanvas();
    if (STATE.tab === "route") drawRouteCanvas();
  }

  function renderField() {
    var m = model();
    return '<div class="'+NS+'-grid">'
      + card("Catch Radius", '<div class="'+NS+'-kpi">'+STATE.catchRadius+'</div><div class="'+NS+'-subk">m operator capture radius</div>', "span-3")
      + card("Approach Velocity", '<div class="'+NS+'-kpi">'+fmt(STATE.approachVel,1)+'</div><div class="'+NS+'-subk">m/s inbound relative speed</div>', "span-3")
      + card("Holding Force", '<div class="'+NS+'-kpi">'+STATE.holdingForce+'</div><div class="'+NS+'-subk">N nominal hold force</div>', "span-3")
      + card("Coil Current", '<div class="'+NS+'-kpi">'+STATE.coilCurrent+'</div><div class="'+NS+'-subk">A active current load</div>', "span-3")
      + card("EM Field Simulation", '<div class="'+NS+'-canvaswrap"><canvas id="'+NS+'-field-canvas"></canvas><div class="'+NS+'-overlay">Catch rings, coil core, approach vector, and field spokes. Green = inbound packet.</div></div>', "span-8")
      + card("Capture State",
          statRow("Mode", esc(STATE.mode), C.purple)
        + statRow("Payload class", esc(STATE.payloadClass), C.cyan)
        + statRow("Capture score", fmt(m.captureScore,1)+"/100", m.captureScore > 78 ? C.green : m.captureScore > 58 ? C.amber : C.red)
        + statRow("Phase lock", fmt(m.phaseLock,1)+"/100", m.phaseLock > 75 ? C.green : m.phaseLock > 55 ? C.amber : C.red)
