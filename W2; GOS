  function forceTableHTML(m) {
    return '<table class="'+NS+'-table"><thead><tr><th>Metric</th><th>Value</th><th>Status</th></tr></thead><tbody>'
      + tableRow("B-coil", m.Bcoil.toExponential(2)+" T", "nominal")
      + tableRow("Capture demand", fmt(m.captureDemand,1), m.captureDemand < m.effectiveHold ? "covered" : "high")
      + tableRow("Effective hold", fmt(m.effectiveHold,1)+" N", "available")
      + tableRow("Momentum", fmt(m.momentum,1)+" kg·m/s", "tracked")
      + tableRow("Launch vector", fmt(m.launchVector,1)+"/100", m.launchVector > 70 ? "ready" : "partial")
      + '</tbody></table>';
